{
  "db_name": "PostgreSQL",
  "query": "SELECT DISTINCT ON (m.device_id, m.sensor_id) m.ts AS timestamp, m.value, s.unit, d.name AS device_name, d.location AS device_location, s.name AS sensor_name\n             FROM measurements m\n             JOIN devices d ON m.device_id = d.id\n             JOIN sensors s ON m.sensor_id = s.id\n             ORDER BY m.device_id, m.sensor_id, ts DESC",
